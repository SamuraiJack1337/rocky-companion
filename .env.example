# ---------------------------------------------------------------------------
# Rocky Companion — example environment file.
#
# Copy this to ".env" (which is git-ignored) ONLY if you are a developer who
# prefers supplying the cloud key via the shell instead of the in-app settings
# UI. Most users should just paste their key into Settings, where it is stored
# encrypted in the macOS Keychain via Electron safeStorage.
#
# This file contains PLACEHOLDER VALUES ONLY. Never put a real key here, and
# never commit a real key anywhere. The repository contains no key and never
# will.
# ---------------------------------------------------------------------------

# Your own OpenAI API key (cloud provider only). Begins with "sk-...".
# Leave blank to use the default, private, on-device Ollama provider.
OPENAI_API_KEY=

# Optional: override the default OpenAI vision model.
# gpt-4o was retired in early 2026 — do NOT use it. Target current GPT-5.x
# vision-capable models. Default is gpt-5.4-mini.
OPENAI_MODEL=gpt-5.4-mini

# Optional: override the local Ollama host / model.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2-vision

{
  "name": "rocky-companion",
  "version": "0.1.3",
  "private": true,
  "description": "A privacy-first desktop companion featuring Rocky as a faceless Eridian engineering collaborator.",
  "license": "MIT",
  "author": "Rocky Companion contributors",
  "main": "dist/main/main.js",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "dev": "node build.mjs --dev",
    "watch": "node build.mjs --dev --watch",
    "start": "electron .",
    "dist:mac": "npm run build && electron-builder --mac",
    "icon": "npm run build && electron scripts/generate-icon.mjs"
  },
  "dependencies": {
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.0",
    "typescript": "^5.7.2"
  }
}
